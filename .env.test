# Test Environment Configuration
NODE_ENV=test

# Server Configuration
PORT=3001
BASE_URL=http://localhost:3001
# Disable rate limiting in test environment
DISABLE_RATE_LIMIT=true

# Supabase Configuration (Test values)
SUPABASE_URL=https://test-project.supabase.co
SUPABASE_ANON_KEY=test-anon-key
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key

# JWT Configuration (Test values)
JWT_SECRET=test-jwt-secret-key-for-testing-only-min-32-chars
JWT_REFRESH_SECRET=test-refresh-token-secret-key-for-testing-only
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3001

# LLM Configuration (Test values)
LLM_API_KEY=test-llm-api-key
LLM_API_URL=https://test-llm-api-endpoint

# Blockchain Configuration (Test values - valid format but for testing only)
BLOCKCHAIN_RPC_URL=http://localhost:8545
BLOCKCHAIN_PRIVATE_KEY=0x1234567890123456789012345678901234567890123456789012345678901234
POLYGON_API_KEY=test-infura-project-id

# Smart Contract Addresses (Test values)
HARDHAT_REPUTATION_ADDRESS=0x1111111111111111111111111111111111111111
HARDHAT_ESCROW_ADDRESS=0x2222222222222222222222222222222222222222
HARDHAT_AGREEMENT_ADDRESS=0x3333333333333333333333333333333333333333
HARDHAT_DISPUTE_ADDRESS=0x4444444444444444444444444444444444444444
HARDHAT_MILESTONE_ADDRESS=0x5555555555555555555555555555555555555555

# Didit KYC Configuration (Test values)
DIDIT_API_KEY=test-didit-api-key
DIDIT_API_URL=https://test-verification.didit.me
DIDIT_WEBHOOK_SECRET=test-didit-webhook-secret-key
DIDIT_WORKFLOW_ID=test-didit-workflow-id