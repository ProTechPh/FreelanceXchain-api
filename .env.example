# =============================================================================
# FreelanceXchain API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] will crash the server if missing.
# Variables marked [PROD-ONLY] crash only when NODE_ENV=production.
# All others are optional with defaults shown.
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
# PORT=3000                                          # HTTP listen port (default: 3000)
# NODE_ENV=development                                # development | test | production
# BASE_URL=http://localhost:3000                      # Override auto-detected base URL
# PUBLIC_URL=http://localhost:5173                    # Public-facing URL for email links
# FRONTEND_URL=http://localhost:5173                  # Frontend app URL for redirects
# ENABLE_API_DOCS=false                               # Enable Swagger UI at /api-docs
# LOG_LEVEL=info                                      # debug | info | warn | error

# ─── Appwrite [REQUIRED] ────────────────────────────────────────────────────
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-api-key

# Appwrite Storage Buckets (defaults shown)
# APPWRITE_PROPOSAL_ATTACHMENTS_BUCKET=proposal-attachments
# APPWRITE_PROJECT_ATTACHMENTS_BUCKET=project-attachments
# APPWRITE_DISPUTE_EVIDENCE_BUCKET=dispute-evidence
# APPWRITE_PORTFOLIO_IMAGES_BUCKET=portfolio-images
# APPWRITE_MILESTONE_DELIVERABLES_BUCKET=milestone-deliverables

# ─── JWT Auth [REQUIRED] ────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-key-min-32-chars-change-this
JWT_REFRESH_SECRET=your-refresh-token-secret-key-min-32-chars   # [PROD-ONLY] Required in production
# JWT_EXPIRES_IN=1h
# JWT_REFRESH_EXPIRES_IN=7d

# ─── CSRF [PROD-ONLY] ───────────────────────────────────────────────────────
# CSRF_SECRET=your-csrf-secret-min-32-chars          # Required in production (separate from JWT_SECRET)

# ─── MFA Encryption [PROD-ONLY] ─────────────────────────────────────────────
# MFA_ENCRYPTION_KEY=your-mfa-encryption-key-32-chars # Required in production (separate from JWT_SECRET)

# ─── CORS ────────────────────────────────────────────────────────────────────
# CORS_ORIGIN=http://localhost:3000,https://your-frontend.com

# ─── LLM / AI Skill Matching [REQUIRED] ────────────────────────────────────
LLM_API_URL=https://api.anthropic.com
LLM_MODEL=claude-haiku-4.5
# LLM_API_KEY=your-api-key                           # Optional auth

# ─── Blockchain ──────────────────────────────────────────────────────────────
# BLOCKCHAIN_MODE=simulated                           # simulated | real (default: simulated)
# BLOCKCHAIN_RPC_URL=http://127.0.0.1:7545           # Ganache / Infura / Polygon RPC
# BLOCKCHAIN_PRIVATE_KEY=your-private-key-hex         # Required when MODE=real
# BLOCKCHAIN_WEBHOOK_SECRET=your-webhook-secret       # HMAC for blockchain webhook verification
# PLATFORM_ARBITER_ADDRESS=0x0000000000000000000000000000000000000001

# ─── Smart Contract Addresses (per-network, all optional) ───────────────────
# HARDHAT_REPUTATION_ADDRESS=
# HARDHAT_ESCROW_ADDRESS=
# HARDHAT_AGREEMENT_ADDRESS=
# HARDHAT_DISPUTE_ADDRESS=
# HARDHAT_MILESTONE_ADDRESS=

# AMOY_REPUTATION_ADDRESS=
# AMOY_ESCROW_ADDRESS=
# AMOY_AGREEMENT_ADDRESS=
# AMOY_DISPUTE_ADDRESS=
# AMOY_MILESTONE_ADDRESS=

# POLYGON_REPUTATION_ADDRESS=
# POLYGON_ESCROW_ADDRESS=
# POLYGON_AGREEMENT_ADDRESS=
# POLYGON_DISPUTE_ADDRESS=
# POLYGON_MILESTONE_ADDRESS=

# MAINNET_REPUTATION_ADDRESS=
# MAINNET_ESCROW_ADDRESS=
# MAINNET_AGREEMENT_ADDRESS=
# MAINNET_DISPUTE_ADDRESS=
# MAINNET_MILESTONE_ADDRESS=

# ─── Didit KYC ──────────────────────────────────────────────────────────────
# DIDIT_API_KEY=your-didit-api-key
# DIDIT_API_URL=https://verification.didit.me
# DIDIT_WEBHOOK_SECRET=your-didit-webhook-secret
# DIDIT_WORKFLOW_ID=your-workflow-id
# ALLOW_INSECURE_DIDIT_WEBHOOKS=false                 # Local-only bypass, keep false in prod

# ─── Email (SMTP) ───────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@freelancexchain.com
