# Server Configuration
PORT=3000
NODE_ENV=development
ALLOW_INSECURE_DIDIT_WEBHOOKS=false
ENABLE_API_DOCS=false


# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-min-32-chars-change-this
JWT_REFRESH_SECRET=your-refresh-token-secret-key-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:3000,https://your-frontend.com

# API docs are disabled by default and must be explicitly enabled
ENABLE_API_DOCS=false

# LLM Configuration (for AI Skill Matching - OpenAI-compatible endpoint)
LLM_API_KEY=YOUR_API_KEY
LLM_API_URL=your_base_url
LLM_MODEL=model_name

# Blockchain Configuration (Ethereum/Sepolia via Infura)
BLOCKCHAIN_RPC_URL=https://sepolia.infura.io/v3/your-infura-project-id
BLOCKCHAIN_PRIVATE_KEY=your-private-key-here
POLYGON_API_KEY=your-infura-project-id

# Blockchain Configuration - Using Hardhat Network for local testing
# BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
# BLOCKCHAIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Blockchain Configuration - Polygon Amoy Testnet (recommended: lowest gas fees)
# BLOCKCHAIN_RPC_URL=https://rpc-amoy.polygon.technology
# AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Blockchain Configuration - Polygon Mainnet (production: low gas fees)
# BLOCKCHAIN_RPC_URL=https://polygon-mainnet.infura.io/v3/your-infura-project-id
# POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/your-infura-project-id

# Smart Contract Addresses (Hardhat - Local Development)
HARDHAT_REPUTATION_ADDRESS=
HARDHAT_ESCROW_ADDRESS=
HARDHAT_AGREEMENT_ADDRESS=
HARDHAT_DISPUTE_ADDRESS=
HARDHAT_MILESTONE_ADDRESS=

# Smart Contract Addresses (Sepolia Testnet)
SEPOLIA_REPUTATION_ADDRESS=
SEPOLIA_ESCROW_ADDRESS=
SEPOLIA_AGREEMENT_ADDRESS=
SEPOLIA_DISPUTE_ADDRESS=
SEPOLIA_MILESTONE_ADDRESS=

# Smart Contract Addresses (Polygon Amoy Testnet)
AMOY_REPUTATION_ADDRESS=
AMOY_ESCROW_ADDRESS=
AMOY_AGREEMENT_ADDRESS=
AMOY_DISPUTE_ADDRESS=
AMOY_MILESTONE_ADDRESS=

# Smart Contract Addresses (Polygon Mainnet)
POLYGON_REPUTATION_ADDRESS=
POLYGON_ESCROW_ADDRESS=
POLYGON_AGREEMENT_ADDRESS=
POLYGON_DISPUTE_ADDRESS=
POLYGON_MILESTONE_ADDRESS=

# Smart Contract Addresses (Ethereum Mainnet)
MAINNET_REPUTATION_ADDRESS=
MAINNET_ESCROW_ADDRESS=
MAINNET_AGREEMENT_ADDRESS=
MAINNET_DISPUTE_ADDRESS=
MAINNET_MILESTONE_ADDRESS=

# Didit KYC Configuration
DIDIT_API_KEY=your-didit-api-key
DIDIT_API_URL=https://verification.didit.me
DIDIT_WEBHOOK_SECRET=your-didit-webhook-secret-key
# Optional local-only bypass. Keep false in all shared/prod environments.
ALLOW_INSECURE_DIDIT_WEBHOOKS=false
DIDIT_WORKFLOW_ID=your-didit-workflow-id

# Blockchain Webhook Configuration
BLOCKCHAIN_WEBHOOK_SECRET=your-blockchain-webhook-secret-key
