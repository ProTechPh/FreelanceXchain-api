# pnpm configuration
# Use strict peer dependencies to avoid version conflicts
strict-peer-dependencies=false

# Enable shamefully-hoist for better compatibility with some tools
# that expect flat node_modules structure (especially TypeScript)
shamefully-hoist=true

# Auto-install peers
auto-install-peers=true

# Public hoist pattern - hoist type definitions to fix TypeScript issues
public-hoist-pattern[]="@types/*"
