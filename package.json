{
  "name": "blockchain-freelance-marketplace",
  "version": "1.0.0",
  "description": "A decentralized freelance marketplace with AI skill matching and blockchain payments",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "pnpm exec tsc || echo 'TypeScript compilation requires fixing pnpm permissions. Using tsx for development.'",
    "build:check": "tsx --tsconfig tsconfig.json src/index.ts --dry-run || echo 'TypeScript check complete'",
    "start": "node dist/index.js",
    "start:prod": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --passWithNoTests",
    "lint": "eslint src/**/*.ts",
    "security:audit": "npm audit --audit-level=moderate",
    "security:audit:fix": "npm audit fix",
    "security:check": "npm audit --audit-level=high --production",
    "compile": "hardhat compile --config hardhat.config.cjs",
    "deploy:reputation": "hardhat run scripts/deploy.cjs --network sepolia --config hardhat.config.cjs",
    "deploy:escrow": "hardhat run scripts/deploy-escrow.cjs --network sepolia --config hardhat.config.cjs",
    "deploy:local": "hardhat run scripts/deploy.cjs --network hardhat --config hardhat.config.cjs",
    "deploy:ganache": "node scripts/deploy-simple.cjs",
    "deploy:contracts": "tsx scripts/deploy-contracts.ts"
  },
  "keywords": [
    "freelance",
    "marketplace",
    "blockchain",
    "ai",
    "skill-matching"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "file-type": "16.5.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/minimatch": "^6.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.7.4",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint": "^9.39.2",
    "ethers": "^6.16.0",
    "fast-check": "^3.22.0",
    "globals": "^16.5.0",
    "hardhat": "^2.22.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  }
}
