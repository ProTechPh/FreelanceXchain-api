{
  "name": "blockchain-freelance-marketplace",
  "version": "1.0.0",
  "description": "A decentralized freelance marketplace with AI skill matching and blockchain payments",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint src/**/*.ts",
    "compile": "npx hardhat compile --config hardhat.config.cjs",
    "deploy:reputation": "npx hardhat run scripts/deploy.cjs --network sepolia --config hardhat.config.cjs",
    "deploy:escrow": "npx hardhat run scripts/deploy-escrow.cjs --network sepolia --config hardhat.config.cjs",
    "deploy:local": "npx hardhat run scripts/deploy.cjs --network hardhat --config hardhat.config.cjs",
    "deploy:ganache": "node scripts/deploy-simple.cjs"
  },
  "keywords": [
    "freelance",
    "marketplace",
    "blockchain",
    "ai",
    "skill-matching"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/cosmos": "^4.2.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.4",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "ethers": "^6.16.0",
    "fast-check": "^3.22.0",
    "hardhat": "^2.22.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
