{
  "name": "blockchain-freelance-marketplace",
  "version": "1.0.0",
  "description": "A decentralized freelance marketplace with AI skill matching and blockchain payments",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "start": "node dist/index.js",
    "start:prod": "tsx src/index.ts",
    "dev": "cross-env NODE_ENV=development BLOCKCHAIN_RPC_URL=http://127.0.0.1:7545 BLOCKCHAIN_PRIVATE_KEY=00ad000e3b3dd62055ba74a187b16a00a86b599a08be5fd4200763b68c380ac7 tsx watch src/index.ts",
    "prod": "cross-env NODE_ENV=production BLOCKCHAIN_RPC_URL=https://rpc-amoy.polygon.technology tsx src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --passWithNoTests",
    "test:plat": "node PLAT/run-plat-test-cases.cjs",
    "lint": "eslint src/**/*.ts",
    "security:audit": "pnpm audit --audit-level=moderate",
    "security:audit:fix": "pnpm audit --fix",
    "security:check": "pnpm audit --audit-level=high --prod",
    "compile": "hardhat compile --config hardhat.config.cjs",
    "deploy:reputation": "hardhat run scripts/deploy.cjs --network sepolia --config hardhat.config.cjs",
    "deploy:escrow": "hardhat run scripts/deploy-escrow.cjs --network sepolia --config hardhat.config.cjs",
    "deploy:local": "node scripts/deploy-to-hardhat.cjs",
    "deploy:contracts": "tsx scripts/deploy-contracts.ts",
    "deploy:contracts:dev": "cross-env BLOCKCHAIN_RPC_URL=http://127.0.0.1:7545 BLOCKCHAIN_PRIVATE_KEY=00ad000e3b3dd62055ba74a187b16a00a86b599a08be5fd4200763b68c380ac7 tsx scripts/deploy-contracts.ts",
    "deploy:contracts:prod": "cross-env BLOCKCHAIN_RPC_URL=https://rpc-amoy.polygon.technology tsx scripts/deploy-contracts.ts",
    "setup:polygon": "tsx scripts/setup-polygon-testnet.ts",
    "check:balance": "tsx scripts/check-balance.ts"
  },
  "keywords": [
    "freelance",
    "marketplace",
    "blockchain",
    "ai",
    "skill-matching"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "file-type": "16.5.4",
    "hcaptcha": "^0.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@jest/globals": "^30.2.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.7.4",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "ethers": "^6.16.0",
    "fast-check": "^3.22.0",
    "globals": "^16.5.0",
    "hardhat": "^2.22.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "pnpm": {
    "strictPeerDependencies": false,
    "shamefullyHoist": true,
    "autoInstallPeers": true,
    "publicHoistPattern": [
      "@types/*"
    ],
    "overrides": {
      "cookie@<0.7.0": ">=0.7.0",
      "tmp@<=0.2.3": ">=0.2.4",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "undici@<6.23.0": ">=6.23.0",
      "bn.js@>=5.0.0 <5.2.3": ">=5.2.3",
      "bn.js@<4.12.3": ">=4.12.3",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=5.0.0 <5.1.7": ">=5.1.7",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "minimatch@>=5.0.0 <5.1.8": ">=5.1.8",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "minimatch@<3.1.4": ">=3.1.4",
      "minimatch": "^3.1.2",
      "test-exclude": "^7.0.1",
      "babel-plugin-istanbul": "^7.0.0",
      "multer@<2.1.0": ">=2.1.0",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "ajv@<6.14.0": ">=6.14.0",
      "multer@<2.1.1": ">=2.1.1",
      "immutable@>=4.0.0-rc.1 <4.3.8": ">=4.3.8"
    }
  }
}
